## ---- IRAN Watch config ----
## Prefer Twitter API (local scheduled)
TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=realDonaldTrump
LOOKBACK_MINUTES=75

## No-API option (best-effort): scrape X.com via Playwright
## Set SCRAPE_X=1 and (recommended) provide a logged-in Playwright storage_state file via X_STORAGE_STATE.
SCRAPE_X=0
X_STORAGE_STATE=
HEADLESS=1

## Optional LLM filter (only if you want it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

## Output JSON location (defaults to static-site/data.json)
OUTPUT_PATH=static-site/data.json

## Fallback (if Twitter API not configured): RSS/Atom feed URL
TRUMP_FEED_URL=

